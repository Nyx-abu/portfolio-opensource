# ─────────────────────────────────────────────────────────────
# DATABASE
# Free tier option: Neon (https://neon.tech) — generous free Postgres
# Copy the connection string from your Neon dashboard.
# Alt: Supabase (https://supabase.com) or Railway (https://railway.app)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NEXTAUTH
# Generate a secret with: openssl rand -base64 32
# (Windows PowerShell: [Convert]::ToBase64String((1..32 | %{Get-Random -Max 256})))
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# ADMIN BOOTSTRAP
# These credentials seed your first admin user (via prisma/seed.ts).
# Change the password immediately after first login.
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# ─────────────────────────────────────────────────────────────
# ANALYTICS (all optional)
# PostHog: https://posthog.com (free tier 1M events/mo)
# Vercel Analytics is zero-config when deployed to Vercel.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─────────────────────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# CLOUDINARY (required for image/video/doc uploads)
# Get keys from https://cloudinary.com/console
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─────────────────────────────────────────────────────────────
# GITHUB OAUTH (optional — enables repo auto-import in admin)
# 1. Create an OAuth App at https://github.com/settings/developers
#    - Application name: anything, e.g. "Portfolio Admin"
#    - Homepage URL: {AUTH_URL}
#    - Authorization callback URL: {AUTH_URL}/api/github/callback
# 2. Scope requested by the app is public_repo (read-only).
# 3. Generate the encryption key with: openssl rand -hex 32
#    (Windows PowerShell:
#      -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) }))
# ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_TOKEN_ENCRYPTION_KEY=""
