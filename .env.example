# ─────────────────────────────────────────────────────────────
# DATABASE
# Free tier option: Neon (https://neon.tech) — generous free Postgres
# Copy the connection string from your Neon dashboard.
# Alt: Supabase (https://supabase.com) or Railway (https://railway.app)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NEXTAUTH
# Generate a secret with: openssl rand -base64 32
# (Windows PowerShell: [Convert]::ToBase64String((1..32 | %{Get-Random -Max 256})))
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# ADMIN BOOTSTRAP
# These credentials seed your first admin user (via prisma/seed.ts).
# Change the password immediately after first login.
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# ─────────────────────────────────────────────────────────────
# ANALYTICS (all optional)
# PostHog: https://posthog.com (free tier 1M events/mo)
# Vercel Analytics is zero-config when deployed to Vercel.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─────────────────────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
